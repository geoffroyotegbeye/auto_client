# URL du backend (Railway en prod, localhost en dev)
# Ce fichier doit être copié en .env.local et rempli localement
# En production (Vercel), définir ces variables dans le dashboard Vercel

NEXT_PUBLIC_API_URL=https://autoserver-production.up.railway.app/api

